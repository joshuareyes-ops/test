{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"settings": {
		"color": {
			"palette": [
				{
					"slug": "primary",
					"color": "#4f46e5",
					"name": "Primary Indigo"
				},
				{
					"slug": "secondary",
					"color": "#10b981",
					"name": "Secondary Emerald"
				},
				{
					"slug": "background",
					"color": "#f8fafc",
					"name": "Light Background"
				},
				{
					"slug": "foreground",
					"color": "#0f172a",
					"name": "Dark Text"
				}
			],
			"custom": false,
			"customGradient": false
		},
		"typography": {
			"fontSizes": [
				{
					"slug": "small",
					"size": "0.875rem",
					"name": "Small"
				},
				{
					"slug": "medium",
					"size": "1rem",
					"name": "Medium"
				},
				{
					"slug": "large",
					"size": "1.5rem",
					"name": "Large"
				},
				{
					"slug": "x-large",
					"size": "2rem",
					"name": "Extra Large"
				}
			],
			"customFontSize": true,
			"fontStyle": true,
			"fontWeight": true,
			"lineHeight": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"blockGap": true,
			"units": ["px", "em", "rem", "vh", "vw", "%"]
		},
		"layout": {
			"contentSize": "800px",
			"wideSize": "1200px"
		},
		"shadow": {
			"presets": [
				{
					"name": "Natural Elevation",
					"slug": "natural-elevation",
					"shadow": "0 10px 20px -5px rgba(0, 0, 0, 0.15), 0 8px 10px -6px rgba(0, 0, 0, 0.1)"
				},
				{
					"name": "Primary Glow",
					"slug": "primary-glow",
					"shadow": "0 0 15px 5px var(--wp--preset--color--primary)"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--background)",
			"text": "var(--wp--preset--color--foreground)"
		},
		"typography": {
			"fontSize": "var(--wp--preset--font-size--medium)"
		},
		"spacing": {
			"blockGap": "1.5rem"
		}
	}
}